{
  "name": "reach-doc-server",
  "version": "1.0.0",
  "main": "server.js",
  "author": "Ekhtiar",
  "license": "MIT",
  "prisma": {
    "schema": "./prisma/schema"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only ./src/server.ts",
    "migrate": "npx prisma migrate dev",
    "build": "tsc",
    "start": "node dist/server.js",
    "reset": "npx prisma migrate reset",
    "commit": "git add . && git commit -m \" chore: updated prisma configuration for deployment and solved 30 type errors  \" && git push",
    "generate": "npx prisma generate",
    "studio": "npx prisma studio",
    "postinstall": "prisma generate --schema=./prisma/schema",
    "stripe:webhook": "stripe listen --forward-to localhost:5000/webhook"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0",
    "stripe": "^22.1.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.5.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^7.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
